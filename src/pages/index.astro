---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/sections/Footer.astro";
import Header from "../components/sections/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../data/consts";
import SkillsSection from "../components/sections/SkillsSection.astro";
import { skills } from "../data/skills";
import WorkExperience from "../components/sections/WorkExperience.astro";
import { work } from "../data/work";

const organizationJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Hold my Spot",
  url: new URL("/", Astro.site).toString(),
  logo: new URL("/favicon.svg", Astro.site).toString(),
  description:
    "La soluzione smart per la prenotazione di parcheggi urbani, riducendo traffico e stress.",
  sameAs: [
    "https://github.com/holdmyspot/",
    // Aggiungi qui altri link social se presenti
  ],
};
---

<!doctype html>
<html lang="it" data-theme="dark" class="dark">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(organizationJsonLd)}
    />
  </head>
  <body>
    <Header />
    <main>
      <section
        class="w-full py-12 md:py-20 border-b border-white/5 bg-grid-white/[0.02]"
      >
        <div class="mx-auto max-w-5xl px-4 text-center">
          <div
            class="inline-flex items-center rounded-full px-3 py-1 text-sm font-medium bg-accent/10 text-accent mb-6"
          >
            Progetto I.T.T.S. Fedi-Fermi
          </div>
          <h1
            class="text-5xl md:text-7xl font-extrabold tracking-tighter text-foreground"
          >
            <span
              class="bg-gradient-to-r from-[var(--accent)] to-[var(--accent-dark)] bg-clip-text text-transparent"
              >Hold my Spot</span
            >
          </h1>
          <p
            class="mt-6 text-xl md:text-2xl text-[color:var(--color-text-secondary)] max-w-3xl mx-auto leading-relaxed"
          >
            La rivoluzione digitale del parcheggio. <br
              class="hidden md:block"
            />
            <span class="text-foreground">Parcheggia in un click</span>,
            abbattendo stress ed emissioni.
          </p>

          <div class="sw-separator-arrow">
            <svg
              class="sw-chevron"
              width="28"
              height="28"
              viewBox="0 0 24 24"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M6 9l6 6 6-6"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
            <span class="sr-only">Scorri</span>
          </div>
        </div>
      </section>

      <section class="py-6">
        <div class="max-w-5xl mx-auto px-4 mb-8">
          <h2 class="text-3xl font-bold text-center">Il Nostro Concept</h2>
        </div>
        <WorkExperience items={work} />

        <div class="sw-separator-arrow">
          <svg
            class="sw-chevron"
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M6 9l6 6 6-6"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
          <span class="sr-only">Scorri</span>
        </div>

        <div class="max-w-5xl mx-auto px-4 mb-8">
          <h2 class="text-3xl font-bold text-center">
            Innovazione e Tecnologia
          </h2>
        </div>
        <SkillsSection skills={skills} />

        <div class="sw-separator-glow" style="--sep-width: 100%;">
          <div class="sw-glow"></div>
          <span class="sr-only">Separator</span>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
